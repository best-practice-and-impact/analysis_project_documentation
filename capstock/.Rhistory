theme(legend.position = "top")+
scale_x_discrete(breaks = unique(itl1$Quarter)[c(T, rep(F, 7))])
itl1 <- itl1 %>% rename(Year = Quarter, gfcf = Value)
itl1_tot <- itl1_tot %>% rename(Year = Quarter, gfcf = Value)
} else {
plot <-   ggplot() +
geom_col(data = itl1 , aes ( x = Year , y = gfcf, fill=ITL1)) +
geom_line(data= itl1_tot , aes(x = Year, y = gfcf), group=1) +
ggtitle(paste0(asset_detail, "_ITL1"))+
theme(legend.position = "top")
}
print(plot)
# ITL1 growth
itl1_tot <- itl1_tot %>% rename(tot_gfcf = gfcf)
itl1 <- left_join(itl1, itl1_tot)
itl1 <- itl1 %>% group_by(ITL1) %>%
arrange(Year) %>%
mutate(ctg = (gfcf-lag(gfcf))/lag(tot_gfcf)) %>%
ungroup() %>%
select(ITL1, Year, ctg) %>%
filter(!is.na(ctg))
itl1_tot <- itl1_tot %>% arrange(Year) %>%
mutate(growth = tot_gfcf/lag(tot_gfcf)-1) %>%
filter(!is.na(growth))
# Do not display characters over 15 characters
itl1$ITL1 <- ifelse(nchar(itl1$ITL1)>20,
paste0(substr(itl1$ITL1,1,17), "..."),
itl1$ITL1)
plot <-   ggplot() +
geom_col(data = itl1 , aes ( x = Year , y = ctg, fill=ITL1)) +
geom_line(data= itl1_tot , aes(x = Year, y = growth), group=1) +
ggtitle(paste0(asset_detail), "_growth_ITL1_")+
theme(legend.position = "top")
if (filename=="estimates"){
print(plot)
}
# ITL 2
itl2 <- df %>% select(ITL1,ITL2, Year, gfcf) %>%
filter(!is.na(ITL2) & ITL2!="")
itl2 <- aggregate(. ~ ITL1+ITL2+Year, data=itl2, FUN=sum)
itl2_tot <- itl2 %>% select(-ITL2)
itl2_tot <- aggregate(. ~ Year+ITL1, data=itl2_tot, FUN=sum)
itl2_tot <- itl2_tot %>% group_by(ITL1) %>%
mutate(grp_gfcf = sum(gfcf)) %>%
ungroup() %>%
arrange(-grp_gfcf, Year)
# Do not display characters over 15 characters
itl2$ITL2 <- ifelse(nchar(itl2$ITL2)>20,
paste0(substr(itl2$ITL2,1,17), "..."),
itl2$ITL2)
for (region in unique(itl2_tot$ITL1)){
itl2_reg <- itl2 %>% filter(ITL1==region)
itl2_tot_reg <- itl2_tot %>% filter(ITL1==region)
plot <-   ggplot() +
geom_col(data = itl2_reg , aes ( x = Year , y = gfcf, fill=ITL2)) +
geom_line(data= itl2_tot_reg , aes(x = Year, y = gfcf), group=1) +
ggtitle(paste0(asset_detail, "_ITL2_",region))+
theme(legend.position = "top")
print(plot)
}
